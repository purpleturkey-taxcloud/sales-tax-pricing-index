{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://taxcloud.com/schemas/provider.json",
  "title": "Sales Tax Provider Pricing Schema",
  "description": "Canonical data model for sales tax provider pricing data. One file per provider.",
  "type": "object",
  "required": [
    "provider",
    "transparency",
    "pricing_model",
    "plans",
    "filings",
    "registrations",
    "transaction_fees",
    "add_ons",
    "sst",
    "international",
    "sources",
    "calculator"
  ],
  "additionalProperties": false,
  "definitions": {
    "confidenceRating": {
      "type": "string",
      "enum": ["A", "B", "C", "D", "E", "F", "G"],
      "description": "A=provider pricing page, B=KB, C=aggregator, D=blog/collateral, E=forum, F=internal, G=estimated"
    },
    "isoDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "pricingValue": {
      "type": "object",
      "properties": {
        "amount": { "type": ["number", "null"] },
        "type": { "type": "string", "enum": ["exact", "starting_at", "range"] },
        "range_min": { "type": ["number", "null"] },
        "range_max": { "type": ["number", "null"] },
        "source": { "type": "string" },
        "source_date": { "$ref": "#/definitions/isoDate" },
        "confidence": { "$ref": "#/definitions/confidenceRating" },
        "discount_pct_vs_monthly": { "type": ["number", "null"] }
      },
      "additionalProperties": false
    },
    "costWithSource": {
      "type": "object",
      "required": ["amount", "confidence"],
      "properties": {
        "amount": { "type": ["number", "null"] },
        "source": { "type": "string" },
        "confidence": { "$ref": "#/definitions/confidenceRating" },
        "range_min": { "type": ["number", "null"] },
        "range_max": { "type": ["number", "null"] }
      },
      "additionalProperties": true
    }
  },
  "properties": {
    "provider": {
      "type": "object",
      "required": ["name", "slug", "primary_url"],
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "legal_name": { "type": ["string", "null"] },
        "parent_company": { "type": ["string", "null"] },
        "hq_location": { "type": ["string", "null"] },
        "founded_year": { "type": ["integer", "null"] },
        "primary_url": { "type": "string", "format": "uri" },
        "pricing_url": { "type": ["string", "null"] },
        "help_center_url": { "type": ["string", "null"] },
        "target_icp": { "type": ["string", "null"] },
        "primary_verticals": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["ecommerce", "saas", "enterprise", "smb", "marketplace", "b2b"]
          }
        },
        "competitive_position": { "type": ["string", "null"] }
      }
    },
    "transparency": {
      "type": "object",
      "required": ["tier"],
      "properties": {
        "tier": { "type": "string", "enum": ["transparent", "partial", "opaque"] },
        "rationale": { "type": "string" },
        "pricing_page_has_dollar_amounts": { "type": "boolean" },
        "quote_required_for_core_product": { "type": "boolean" },
        "publishes_filing_fees": { "type": "boolean" },
        "publishes_registration_fees": { "type": "boolean" },
        "publishes_overage_rates": { "type": "boolean" },
        "publishes_implementation_fees": { "type": "boolean" }
      }
    },
    "pricing_model": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": {
          "type": "string",
          "enum": ["subscription_tiered", "per_region_flat", "per_filing", "per_transaction", "hybrid", "percent_of_revenue", "custom_quote"]
        },
        "scales_with": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["orders", "transactions", "revenue", "states", "filings", "jurisdictions", "seats"]
          }
        },
        "predictability_score": { "type": "integer", "minimum": 1, "maximum": 5 },
        "predictability_notes": { "type": "string" }
      }
    },
    "plans": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "slug", "is_free", "is_quote_only", "monthly_price"],
        "properties": {
          "name": { "type": "string" },
          "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "tagline": { "type": ["string", "null"] },
          "target_customer": { "type": ["string", "null"] },
          "is_free": { "type": "boolean" },
          "is_quote_only": { "type": "boolean" },
          "monthly_price": { "$ref": "#/definitions/pricingValue" },
          "annual_price": { "$ref": "#/definitions/pricingValue" },
          "order_tiers": { "type": "array" },
          "overage": { "type": "object" },
          "included_filings_per_period": { "type": "object" },
          "included_integrations": { "type": ["integer", "null"] },
          "included_states": { "type": ["integer", "null"] },
          "api_access_included": { "type": "boolean" },
          "features": { "type": "object" },
          "per_filing_cost_override": { "type": ["number", "null"] },
          "per_registration_cost_override": { "type": ["number", "null"] },
          "transaction_fee_rate_override": { "type": ["number", "null"] }
        }
      }
    },
    "filings": {
      "type": "object",
      "required": ["has_per_filing_fee", "base_cost"],
      "properties": {
        "has_per_filing_fee": { "type": "boolean" },
        "base_cost": { "$ref": "#/definitions/costWithSource" },
        "state_upcharges": { "type": "array" },
        "volume_discounts": { "type": "array" },
        "notes": { "type": "string" }
      }
    },
    "registrations": {
      "type": "object",
      "required": ["has_per_registration_fee", "base_cost"],
      "properties": {
        "has_per_registration_fee": { "type": "boolean" },
        "base_cost": { "$ref": "#/definitions/costWithSource" },
        "includes_state_fees": { "type": ["boolean", "null"] },
        "notes": { "type": "string" }
      }
    },
    "transaction_fees": {
      "type": "object",
      "required": ["has_transaction_fee"],
      "properties": {
        "has_transaction_fee": { "type": "boolean" },
        "model": { "type": ["string", "null"], "enum": ["flat_per_txn", "basis_points", "percent", "tiered", null] },
        "rate": { "type": ["number", "null"] },
        "rate_unit": { "type": ["string", "null"] },
        "applies_to": { "type": ["string", "null"] },
        "notes": { "type": "string" }
      }
    },
    "add_ons": { "type": "object" },
    "sst": {
      "type": "object",
      "required": ["is_csp"],
      "properties": {
        "is_csp": { "type": "boolean" },
        "sst_member_states_covered_free": { "type": ["integer", "null"] },
        "eligibility_requirements": { "type": "string" },
        "filings_covered_under_csp": { "type": "boolean" },
        "source": { "type": "string" }
      }
    },
    "international": {
      "type": "object",
      "properties": {
        "supports_vat": { "type": "boolean" },
        "supports_gst": { "type": "boolean" },
        "countries_covered": { "type": ["integer", "null"] },
        "pricing_model_international": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "discounts": { "type": "object" },
    "commitments": { "type": "object" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["url", "confidence"],
        "properties": {
          "url": { "type": "string" },
          "title": { "type": "string" },
          "accessed_date": { "$ref": "#/definitions/isoDate" },
          "confidence": { "$ref": "#/definitions/confidenceRating" },
          "fields_supported": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "change_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "change_type", "description"],
        "properties": {
          "date": { "$ref": "#/definitions/isoDate" },
          "change_type": {
            "type": "string",
            "enum": ["price_increase", "price_decrease", "new_plan", "discontinued_plan", "structure_change"]
          },
          "description": { "type": "string" },
          "source": { "type": "string" }
        }
      }
    },
    "calculator": {
      "type": "object",
      "required": ["cost_formula_notes"],
      "properties": {
        "applicable_inputs": { "type": "array", "items": { "type": "string" } },
        "cost_formula_notes": { "type": "string" },
        "output_caveat": { "type": "string" }
      }
    },
    "notes": { "type": "string" }
  }
}
